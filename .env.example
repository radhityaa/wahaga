# =================================
# WhatsApp Gateway - Environment Configuration
# =================================
# Copy this file to .env and edit the values
# =================================

# Environment mode
NODE_ENV=development
PORT=3000

# =================================
# Database (SQLite - Built-in)
# =================================
# Default: Uses built-in SQLite database
# Optional: Use external MySQL by setting DATABASE_URL
# DATABASE_URL="mysql://user:password@host:3306/database"

# =================================
# Redis Cache (Optional)
# =================================
# Leave empty to use in-memory cache
# REDIS_URL="redis://localhost:6379"

# =================================
# SECURITY
# =================================
# API Key - Required for all API requests
# Supports plain text or SHA512 hash
# Plain: API_KEY=your-secret-key
# Hashed: API_KEY=sha512:your-sha512-hash
# Generate hash: echo -n "your-key" | sha512sum
API_KEY=your-secret-api-key-change-me

# =================================
# Swagger Documentation (Optional)
# =================================
SWAGGER_ENABLED=true
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# =================================
# Dashboard Security (Optional)
# =================================
DASHBOARD_ENABLED=true
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# =================================
# Default Webhook (Optional)
# =================================
WEBHOOK_URL=
WEBHOOK_EVENTS=*

# =================================
# WHATSAPP SETTINGS
# =================================
WA_MAX_SESSIONS=20
WA_SESSION_DIR=./storage/sessions

# =================================
# FILE UPLOAD
# =================================
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=50000000

# =================================
# WEBHOOK SETTINGS
# =================================
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRIES=3

# =================================
# RATE LIMITING
# =================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# LOGGING
# =================================
LOG_LEVEL=info
